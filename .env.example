# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=llama3.1:8b
OLLAMA_FAST_MODEL=mistral:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./jdass.db

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8501
API_PORT=8000

# ── Scraping ──────────────────────────────────────────────────────────────────
# Optional: Wellfound session cookie for authenticated scraping
WELLFOUND_SESSION_COOKIE=

# LinkedIn cookies (if needed for scraping)
LINKEDIN_LI_AT=

# ── Notifications ─────────────────────────────────────────────────────────────
# macOS notifications via osascript — no config needed
ENABLE_NOTIFICATIONS=true

# ── Rate limiting ─────────────────────────────────────────────────────────────
MAX_APPLICATIONS_PER_HOUR=10
SCRAPER_REQUEST_DELAY_SECONDS=2
